{
  "name": "shippage",
  "version": "0.1.0",
  "description": "Turn your changelog into a release marketing page in one click.",
  "license": "MIT",
  "bin": {
    "shippage": "./bin/cli.js"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.30.1",
    "better-sqlite3": "11.3.0",
    "commander": "12.1.0",
    "cors": "2.8.5",
    "express": "4.21.1",
    "handlebars": "4.7.8",
    "inquirer": "9.3.7",
    "keytar": "7.9.0",
    "open": "10.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.27.0",
    "sanitize-html": "2.13.0",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@types/better-sqlite3": "7.6.12",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/react-router-dom": "5.3.3",
    "@types/sanitize-html": "2.13.0",
    "@types/uuid": "10.0.0",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.0",
    "eslint": "9.14.0",
    "@eslint/js": "9.14.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "globals": "15.12.0",
    "postcss": "8.4.49",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.14.0",
    "vite": "5.4.10",
    "vitest": "2.1.5"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "optionalDependencies": {
    "keytar": "7.9.0"
  }
}
